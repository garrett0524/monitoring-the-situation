# Copy this file to .env and fill in your keys. NEVER commit .env to git.

# Mapbox — get from mapbox.com dashboard. Restrict to your domain in production.
MAPBOX_TOKEN=your_mapbox_token
VITE_MAPBOX_TOKEN=your_mapbox_token   # same token, exposed to client (domain-restricted)

# News APIs
NEWSAPI_KEY=your_newsapi_key          # newsapi.org
GNEWS_API_KEY=your_gnews_key          # gnews.io

# AI analysis (server-side only — never expose to client)
ANTHROPIC_API_KEY=your_anthropic_key

# Social signals — optional. If unset, falls back to curated mock posts.
X_BEARER_TOKEN=your_x_bearer_token

# Aircraft tracking — currently unused
ADSB_API_KEY=your_adsb_key

# Server
PORT=3001
VITE_API_URL=http://localhost:3001
